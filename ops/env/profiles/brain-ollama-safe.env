# Local Brain safe canary profile (Ollama) for local-v2 stack.
# Use this when you want Monday-open canary enablement without applying
# Brain latency to every pocket/strategy.
#
# Refresh readiness and sync the preflight model into this profile with:
#   python3 scripts/prepare_local_brain_canary.py

BRAIN_ENABLED=1
ORDER_MANAGER_BRAIN_GATE_ENABLED=1
ORDER_MANAGER_BRAIN_GATE_MODE=shadow
ORDER_MANAGER_BRAIN_GATE_APPLY_WITH_PRESERVE_INTENT=1
ORDER_MANAGER_SERVICE_WORKERS=1

BRAIN_BACKEND=ollama
BRAIN_PROFILE_MODE=profit
BRAIN_OLLAMA_URL=http://127.0.0.1:11434/api/chat
BRAIN_OLLAMA_MODEL=qwen2.5:7b
BRAIN_OLLAMA_KEEP_ALIVE=-1

# Keep scope narrow until Monday live verification proves otherwise.
BRAIN_POCKET_ALLOWLIST=micro
BRAIN_STRATEGY_ALLOWLIST=MomentumBurst,MicroLevelReactor,MicroRangeBreak,MicroTrendRetest

# Micro-only canary: full sampling with in-process autotune, fail-open on latency.
BRAIN_SAMPLE_RATE=1.0
BRAIN_TTL_SEC=15
BRAIN_FAIL_POLICY=allow
BRAIN_FAIL_POLICY_MICRO=allow
BRAIN_TIMEOUT_SEC=4
BRAIN_TIMEOUT_SEC_MICRO=4
BRAIN_MIN_SCALE=0.50
BRAIN_MAX_CONTEXT_CHARS=900
BRAIN_MAX_TOKENS=192

# Keep these synced to the latest benchmark and let the live shadow lane self-tune.
BRAIN_PROMPT_PROFILE_PATH=config/brain_prompt_profile_profit_micro.json
BRAIN_PROMPT_REPORT_LATEST_PATH=logs/brain_prompt_autotune_profit_latest.json
BRAIN_PROMPT_REPORT_HISTORY_PATH=logs/brain_prompt_autotune_profit_history.jsonl
BRAIN_PROMPT_AUTO_TUNE_MODEL=qwen2.5:7b
BRAIN_RUNTIME_PARAM_AUTO_TUNE_MODEL=qwen2.5:7b
BRAIN_PROMPT_AUTO_TUNE_ENABLED=1
BRAIN_PROMPT_AUTO_TUNE_INTERVAL_SEC=300
BRAIN_PROMPT_AUTO_TUNE_MIN_DECISIONS=8
BRAIN_PROMPT_AUTO_TUNE_LOOKBACK_HOURS=12
BRAIN_RUNTIME_PARAM_PROFILE_PATH=config/brain_runtime_param_profile_profit_micro.json
BRAIN_RUNTIME_PARAM_REPORT_LATEST_PATH=logs/brain_runtime_param_autotune_profit_latest.json
BRAIN_RUNTIME_PARAM_REPORT_HISTORY_PATH=logs/brain_runtime_param_autotune_profit_history.jsonl
BRAIN_RUNTIME_PARAM_AUTO_TUNE_ENABLED=1
BRAIN_RUNTIME_PARAM_AUTO_TUNE_INTERVAL_SEC=300
BRAIN_RUNTIME_PARAM_AUTO_TUNE_MIN_DECISIONS=6
BRAIN_RUNTIME_PARAM_AUTO_TUNE_LOOKBACK_HOURS=12
