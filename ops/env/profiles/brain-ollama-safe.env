# Local Brain safe canary profile (Ollama) for local-v2 stack.
# Use this when you want Monday-open canary enablement without applying
# Brain latency to every pocket/strategy.
#
# Refresh readiness and sync the preflight model into this profile with:
#   python3 scripts/prepare_local_brain_canary.py

BRAIN_ENABLED=1
ORDER_MANAGER_BRAIN_GATE_ENABLED=1
ORDER_MANAGER_BRAIN_GATE_MODE=shadow
ORDER_MANAGER_BRAIN_GATE_APPLY_WITH_PRESERVE_INTENT=1
ORDER_MANAGER_SERVICE_WORKERS=1

BRAIN_BACKEND=ollama
BRAIN_OLLAMA_URL=http://127.0.0.1:11434/api/chat
BRAIN_OLLAMA_MODEL=qwen2.5:7b

# Keep scope narrow until Monday live verification proves otherwise.
BRAIN_POCKET_ALLOWLIST=micro
BRAIN_STRATEGY_ALLOWLIST=MomentumBurst,MicroLevelReactor,MicroRangeBreak,MicroTrendRetest

# Micro-only canary: low sampling, cache reuse, fail-open on latency.
BRAIN_SAMPLE_RATE=0.35
BRAIN_TTL_SEC=15
BRAIN_FAIL_POLICY=allow
BRAIN_FAIL_POLICY_MICRO=allow
BRAIN_TIMEOUT_SEC=4
BRAIN_TIMEOUT_SEC_MICRO=4
BRAIN_MIN_SCALE=0.50
BRAIN_MAX_CONTEXT_CHARS=900
BRAIN_MAX_TOKENS=192

# Keep these synced to the latest benchmark even though auto-tune is off here.
BRAIN_PROMPT_AUTO_TUNE_MODEL=gpt-oss:20b
BRAIN_RUNTIME_PARAM_AUTO_TUNE_MODEL=gpt-oss:20b
BRAIN_PROMPT_AUTO_TUNE_ENABLED=0
BRAIN_RUNTIME_PARAM_AUTO_TUNE_ENABLED=0
