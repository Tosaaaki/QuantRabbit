# Safe local Brain profile (Ollama) for local-v2 stack.
#
# Goal:
# - Use local LLM to improve trade quality
# - Keep order_manager preflight latency bounded (avoid always-on heavy auto-tune)
#
# Load via either:
# 1) LOCAL_V2_EXTRA_ENV_FILES=ops/env/profiles/brain-ollama-safe.env
# 2) --env ops/env/local-v2-stack.env,ops/env/profiles/brain-ollama-safe.env

BRAIN_ENABLED=1
ORDER_MANAGER_BRAIN_GATE_ENABLED=1
ORDER_MANAGER_BRAIN_GATE_APPLY_WITH_PRESERVE_INTENT=1

# Local-only backend
BRAIN_BACKEND=ollama
BRAIN_OLLAMA_URL=http://127.0.0.1:11434/api/chat
BRAIN_OLLAMA_MODEL=qwen2.5:7b

# Conservative preflight settings
# - Cache decisions per (strategy_tag, pocket) to avoid frequent LLM calls
# - Fail open (allow) to avoid blocking trades on LLM timeouts
BRAIN_SAMPLE_RATE=1.0
BRAIN_TTL_SEC=90
BRAIN_FAIL_POLICY=allow
BRAIN_TIMEOUT_SEC=3
BRAIN_MAX_TOKENS=192

# Start small: only apply to micro pocket by default (expand as needed).
BRAIN_POCKET_ALLOWLIST=micro

# Disable auto-tune loops in safe profile (enable only in explicit experiments).
BRAIN_PROMPT_AUTO_TUNE_ENABLED=0
BRAIN_RUNTIME_PARAM_AUTO_TUNE_ENABLED=0

