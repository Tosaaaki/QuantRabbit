# Local Brain profile (Ollama) for local-v2 stack.
# Load via either:
# 1) LOCAL_V2_EXTRA_ENV_FILES=ops/env/profiles/brain-ollama.env
# 2) --env ops/env/local-v2-stack.env,ops/env/profiles/brain-ollama.env

BRAIN_ENABLED=1
ORDER_MANAGER_BRAIN_GATE_ENABLED=1
ORDER_MANAGER_BRAIN_GATE_APPLY_WITH_PRESERVE_INTENT=1

BRAIN_BACKEND=ollama
BRAIN_OLLAMA_URL=http://127.0.0.1:11434/api/chat
BRAIN_OLLAMA_MODEL=gpt-oss:20b

# Aggressive local usage with short cache and fail-safe reduce policy.
BRAIN_SAMPLE_RATE=1.0
BRAIN_TTL_SEC=5
BRAIN_FAIL_POLICY=reduce
# Keep preflight latency bounded; heavy reasoning is shifted to async auto-tune loops.
BRAIN_TIMEOUT_SEC=6
BRAIN_MAX_TOKENS=256

# Prompt auto-tune loop (local LLM): decision history -> analysis -> prompt update.
BRAIN_PROMPT_AUTO_TUNE_ENABLED=1
BRAIN_PROMPT_AUTO_TUNE_INTERVAL_SEC=300
BRAIN_PROMPT_AUTO_TUNE_MIN_DECISIONS=40
BRAIN_PROMPT_AUTO_TUNE_LOOKBACK_HOURS=24
BRAIN_PROMPT_PROFILE_PATH=config/brain_prompt_profile.json
BRAIN_PROMPT_AUTO_TUNE_MODEL=gpt-oss:20b
BRAIN_PROMPT_AUTO_TUNE_TIMEOUT_SEC=70
BRAIN_PROMPT_AUTO_TUNE_MAX_TOKENS=2048
BRAIN_PROMPT_REPORT_LATEST_PATH=logs/brain_prompt_autotune_latest.json
BRAIN_PROMPT_REPORT_HISTORY_PATH=logs/brain_prompt_autotune_history.jsonl

# Runtime param auto-tune (local LLM): performance + market summary -> dynamic guard params.
BRAIN_RUNTIME_PARAM_PROFILE_PATH=config/brain_runtime_param_profile.json
BRAIN_RUNTIME_PARAM_AUTO_TUNE_ENABLED=1
BRAIN_RUNTIME_PARAM_AUTO_TUNE_INTERVAL_SEC=300
BRAIN_RUNTIME_PARAM_AUTO_TUNE_MIN_DECISIONS=40
BRAIN_RUNTIME_PARAM_AUTO_TUNE_LOOKBACK_HOURS=24
BRAIN_RUNTIME_PARAM_AUTO_TUNE_MODEL=gpt-oss:20b
BRAIN_RUNTIME_PARAM_AUTO_TUNE_TIMEOUT_SEC=70
BRAIN_RUNTIME_PARAM_AUTO_TUNE_MAX_TOKENS=2048
BRAIN_RUNTIME_PARAM_REPORT_LATEST_PATH=logs/brain_runtime_param_autotune_latest.json
BRAIN_RUNTIME_PARAM_REPORT_HISTORY_PATH=logs/brain_runtime_param_autotune_history.jsonl
