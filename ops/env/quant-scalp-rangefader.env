# Dedicated env for quant-scalp-rangefader.service (RangeFader)
RANGEFADER_ENABLED=1
RANGEFADER_POCKET=scalp
RANGEFADER_LOOP_INTERVAL_SEC=3.0
RANGEFADER_LOG_PREFIX=[RangeFader]
# 2026-03-11: 低品質fade遮断 → confidence floorを大幅引き上げ
RANGEFADER_CONFIDENCE_FLOOR=50
RANGEFADER_CONFIDENCE_CEIL=90
RANGEFADER_MIN_UNITS=1200
# 2026-03-11: 損失源 → 最小観察モード。勝ちパターン確認後に戻す
RANGEFADER_BASE_UNITS=1000
RANGEFADER_CAP_MIN=0.1
RANGEFADER_CAP_MAX=1.0
RANGEFADER_COOLDOWN_SEC=20.0
# 2026-03-11: 同時ポジ数制限（4→2）リスク集中回避
RANGEFADER_MAX_OPEN_TRADES=2
RANGEFADER_MAX_OPEN_TRADES_GLOBAL=0
RANGEFADER_OPEN_TRADES_SCOPE=tag
RANGEFADER_RANGE_ONLY_SCORE=0.40
RANGEFADER_SIZE_MULT_BASE=1.25
RANGEFADER_SIZE_MULT_SCORE_START=0.45
RANGEFADER_SIZE_MULT_SLOPE=0.70
RANGEFADER_SIZE_MULT_MIN=0.90
RANGEFADER_SIZE_MULT_MAX=1.50
RANGEFADER_SIZE_MULT_MIN_FMR=0.12
RANGEFADER_BB_ENTRY_ENABLED=1

# strategy_entry leading profile (RangeFader / range-priority)
RANGEFADER_ENTRY_LEADING_PROFILE_ENABLED=1
# 2026-03-11: reject閾値引き上げ（0.30→0.50）低品質trade完全遮断
RANGEFADER_ENTRY_LEADING_PROFILE_REJECT_BELOW=0.50
RANGEFADER_ENTRY_LEADING_PROFILE_BOOST_MAX=0.10
RANGEFADER_ENTRY_LEADING_PROFILE_PENALTY_MAX=0.20
RANGEFADER_ENTRY_LEADING_PROFILE_UNITS_MIN_MULT=0.50
RANGEFADER_ENTRY_LEADING_PROFILE_UNITS_MAX_MULT=1.25
RANGEFADER_ENTRY_LEADING_PROFILE_WEIGHT_FORECAST=0.25
RANGEFADER_ENTRY_LEADING_PROFILE_WEIGHT_TECH=0.22
RANGEFADER_ENTRY_LEADING_PROFILE_WEIGHT_RANGE=0.40
RANGEFADER_ENTRY_LEADING_PROFILE_WEIGHT_MICRO=0.08
RANGEFADER_ENTRY_LEADING_PROFILE_WEIGHT_PATTERN=0.05
