SCALP_PING_5S_B_LOOKAHEAD_EDGE_MIN_PIPS=0.65
SCALP_PING_5S_B_LOOKAHEAD_UNITS_MAX_MULT=1.00
SCALP_PING_5S_B_DYN_ALLOC_MULT_MAX=1.20
SCALP_PING_5S_B_TP_ENABLED=1
# 2026-03-11: shared perf floor は通常値へ戻す。participation 回復は
# strategy-local / setup-scoped 改善で行い、全戦略一律のサイズ緩和は使わない。
RISK_PERF_MIN_MULT=0.70

# order_manager protection fallback gap (price). 0.12 is too wide for scalp_fast,
# but 0.02 (2p) reintroduced STOP_LOSS_ON_FILL_LOSS rejects during 2026-03-06 recovery.
ORDER_PROTECTION_FALLBACK_PIPS_SCALP_FAST=0.03

