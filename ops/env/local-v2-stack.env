# Local override profile for `scripts/local_v2_stack.sh`.
#
# Keep this file intentionally minimal. Base runtime values come from:
#   ops/env/quant-v2-runtime.env
#
# Add temporary local-only overrides here when running fast PDCA loops.
# Example:
#   SCALP_PING_5S_B_SIDE_FILTER=sell
#   SCALP_PING_5S_B_SHORT_PROBE_RESCUE_ENABLED=0
DISABLE_GCP_SECRET_MANAGER=1
POSITION_MANAGER_SERVICE_FALLBACK_LOCAL=1
POSITION_MANAGER_SERVICE_FAIL_BACKOFF_SEC=1.0
POSITION_MANAGER_SERVICE_FAIL_BACKOFF_MAX_SEC=6.0
ORDER_MANAGER_PATTERN_GATE_ENABLED=1

# 2026-03-05 profitability fix (local V2):
# - hard stop は解除し、戦略側のフィルタ強化でリスクを制御する（停止で逃げない）。
# - exit は止めない（open trade の保護を優先）。
STRATEGY_CONTROL_ENTRY_SCALP_PING_5S_B=1
STRATEGY_CONTROL_ENTRY_SCALP_PING_5S_C=1
STRATEGY_CONTROL_ENTRY_SCALP_PING_5S_D=1
STRATEGY_CONTROL_ENTRY_SCALP_PING_5S_FLOW=1
STRATEGY_CONTROL_ENTRY_MICROPULLBACKEMA=1
STRATEGY_CONTROL_ENTRY_MICROTRENDRETEST=1

# 2026-03-05 local-v2 recovery/tuning:
# - keep B live but suppress long-side loss concentration
# - tighten C/D/Flow low-quality entries with dynamic thresholds
# - shrink D/Flow oversized units to reduce margin-cap churn
SCALP_PING_5S_B_SIDE_FILTER=sell
SCALP_PING_5S_B_ALLOW_NO_SIDE_FILTER=0
SCALP_PING_5S_B_DIRECTION_BIAS_LONG_OPPOSITE_UNITS_MULT=0.15
SCALP_PING_5S_B_LOOKAHEAD_GATE_ENABLED=1
SCALP_PING_5S_B_LOOKAHEAD_ALLOW_THIN_EDGE=1
SCALP_PING_5S_B_LOOKAHEAD_UNITS_MIN_MULT=0.25
SCALP_PING_5S_B_LOOKAHEAD_SLIP_SPREAD_MULT=0.18
SCALP_PING_5S_B_LOOKAHEAD_SLIP_RANGE_MULT=0.08
SCALP_PING_5S_B_LOOKAHEAD_LATENCY_PENALTY_PIPS=0.01
SCALP_PING_5S_B_MIN_SIGNAL_TICKS=5
SCALP_PING_5S_B_LONG_MIN_SIGNAL_TICKS=5
SCALP_PING_5S_B_SHORT_MIN_SIGNAL_TICKS=5
SCALP_PING_5S_B_SIGNAL_MODE_BLOCKLIST=
SCALP_PING_5S_B_MAX_ACTIVE_TRADES=4
SCALP_PING_5S_B_MAX_PER_DIRECTION=2
SCALP_PING_5S_B_ENTRY_LEADING_PROFILE_REJECT_BELOW=0.80
SCALP_PING_5S_B_ENTRY_LEADING_PROFILE_REJECT_BELOW_SHORT=0.86
SCALP_PING_5S_B_ENTRY_PROBABILITY_ALIGN_FLOOR=0.62
SCALP_PING_5S_B_BASE_ENTRY_UNITS=18
SCALP_PING_5S_B_TP_ENABLED=1
RISK_PERF_MIN_MULT=0.55

SCALP_PING_5S_C_LOOKAHEAD_GATE_ENABLED=1
SCALP_PING_5S_C_MIN_SIGNAL_TICKS=3
SCALP_PING_5S_C_ENTRY_LEADING_PROFILE_REJECT_BELOW=0.74
SCALP_PING_5S_C_ENTRY_LEADING_PROFILE_REJECT_BELOW_SHORT=0.80
SCALP_PING_5S_C_ENTRY_PROBABILITY_ALIGN_FLOOR=0.52
SCALP_PING_5S_C_MAX_SPREAD_PIPS=1.20

SCALP_PING_5S_D_LOOKAHEAD_GATE_ENABLED=1
SCALP_PING_5S_D_MIN_SIGNAL_TICKS=3
SCALP_PING_5S_D_ENTRY_LEADING_PROFILE_REJECT_BELOW=0.66
SCALP_PING_5S_D_ENTRY_LEADING_PROFILE_REJECT_BELOW_SHORT=0.74
SCALP_PING_5S_D_ENTRY_PROBABILITY_ALIGN_FLOOR=0.55
SCALP_PING_5S_D_BASE_ENTRY_UNITS=4200
SCALP_PING_5S_D_MAX_ACTIVE_TRADES=1
SCALP_PING_5S_D_MAX_PER_DIRECTION=1
SCALP_PING_5S_D_DIRECTION_BIAS_LONG_OPPOSITE_UNITS_MULT=0.30
SCALP_PING_5S_D_FORCE_EXIT_MAX_FLOATING_LOSS_PIPS=0.65
SCALP_PING_5S_D_SHORT_FORCE_EXIT_MAX_FLOATING_LOSS_PIPS=0.55
SCALP_PING_5S_D_MAX_SPREAD_PIPS=1.20

SCALP_PING_5S_FLOW_LOOKAHEAD_GATE_ENABLED=1
SCALP_PING_5S_FLOW_MIN_SIGNAL_TICKS=3
SCALP_PING_5S_FLOW_ENTRY_LEADING_PROFILE_REJECT_BELOW=0.40
SCALP_PING_5S_FLOW_ENTRY_LEADING_PROFILE_REJECT_BELOW_SHORT=0.52
SCALP_PING_5S_FLOW_BASE_ENTRY_UNITS=700
SCALP_PING_5S_FLOW_MAX_ACTIVE_TRADES=6
SCALP_PING_5S_FLOW_MAX_PER_DIRECTION=3

# 2026-03-05 local LLM (Brain gate) profile layering.
# Brain gate is **disabled by default** for local V2 because scalp preflight is latency-sensitive.
# Enable only when you explicitly want it:
# - Safe (micro-only, fail-open, longer TTL):
#   scripts/local_v2_stack.sh up --profile <...> --env ops/env/local-v2-stack.env,ops/env/profiles/brain-ollama-safe.env
# - Aggressive experiments (all pockets + auto-tune):
#   scripts/local_v2_stack.sh up --profile <...> --env ops/env/local-v2-stack.env,ops/env/profiles/brain-ollama.env
LOCAL_V2_EXTRA_ENV_FILES=

# 2026-03-05 dynamic reentry profile (local V2):
