# 2026-03-09 local LLM (Brain gate) profile layering.
# Keep the local V2 default on the safe Brain canary so manual restart, watchdog,
# and launchd recovery all preserve the same trade path.
# - Safe canary (micro-only, fail-open, auto-tune off):
#   python3 scripts/prepare_local_brain_canary.py
#   scripts/local_v2_stack.sh restart --profile trade_min \
#     --env ops/env/local-v2-stack.env \
#     --services quant-order-manager,quant-strategy-control
# - Aggressive offline experiments (all pockets + auto-tune):
#   scripts/local_v2_stack.sh up --profile <...> --env ops/env/local-v2-stack.env,ops/env/profiles/brain-ollama.env
LOCAL_V2_EXTRA_ENV_FILES=ops/env/profiles/brain-ollama-safe.env

# local_v2_stack has no systemd timer lane, so keep strategy feedback alive as a
# lightweight loop here. `execution/strategy_entry.py` consumes this JSON directly.
STRATEGY_FEEDBACK_LOOP_SEC=120

