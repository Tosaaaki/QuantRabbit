# Local override profile for `scripts/local_v2_stack.sh`.
#
# Keep this file intentionally minimal. Base runtime values come from:
#   ops/env/quant-v2-runtime.env
#
# Add temporary local-only overrides here when running fast PDCA loops.
# Example:
#   SCALP_PING_5S_B_SIDE_FILTER=sell
#   SCALP_PING_5S_B_SHORT_PROBE_RESCUE_ENABLED=0
# === 2026-03-17 aggressive 30min sprint: 34,642 JPY / 1:25 / spread 0.8pip ===
GLOBAL_DD_EQUITY_BASE_JPY=34642
RISK_MAX_LOT=12.0
MAX_MARGIN_USAGE=0.90
MAX_MARGIN_USAGE_HARD=0.92
SCALP_TACTICAL=1
DISABLE_POCKET_DD=1
DISABLE_GCP_SECRET_MANAGER=1
POSITION_MANAGER_SERVICE_FALLBACK_LOCAL=1
POSITION_MANAGER_SERVICE_FAIL_BACKOFF_SEC=1.0
POSITION_MANAGER_SERVICE_FAIL_BACKOFF_MAX_SEC=6.0
POSITION_MANAGER_WORKER_SYNC_TRADES_TIMEOUT_SEC=20.0
POSITION_MANAGER_WORKER_SYNC_TRADES_MAX_FETCH=200
POSITION_MANAGER_WORKER_BACKGROUND_SYNC_ENABLED=1
POSITION_MANAGER_WORKER_BACKGROUND_SYNC_START_DELAY_SEC=1
POSITION_MANAGER_WORKER_BACKGROUND_SYNC_INTERVAL_SEC=5
POSITION_MANAGER_WORKER_BACKGROUND_SYNC_MAX_FETCH=120
ORDER_MANAGER_PATTERN_GATE_ENABLED=1
# trade_all で order_manager 呼び出しが read timeout=8.0 で落ちやすい（worker側skip増）ため上書き
ORDER_OANDA_REQUEST_TIMEOUT_SEC=10.0
ORDER_MANAGER_SERVICE_TIMEOUT=14.0
# absorb brief OANDA /summary flaps with bounded stale-cache reuse.
# 2026-03-07 local V2: extend to 60s so minute-scale 503 bursts reuse the last
# healthy snapshot instead of hard-rejecting entries while free margin is ample.
ORDER_MARGIN_STALE_ALLOW_SEC=60
ORDER_MARGIN_STALE_MIN_FREE_RATIO=0.30
ORDER_MARGIN_STALE_MIN_HEALTH_BUFFER=0.25

# 2026-03-05 profitability fix (local V2):
# - hard stop は解除し、戦略側のフィルタ強化でリスクを制御する（停止で逃げない）。
# - exit は止めない（open trade の保護を優先）。
STRATEGY_CONTROL_ENTRY_SCALP_PING_5S_B=1
STRATEGY_CONTROL_ENTRY_SCALP_PING_5S_C=1
STRATEGY_CONTROL_ENTRY_SCALP_PING_5S_D=1
STRATEGY_CONTROL_ENTRY_SCALP_PING_5S_FLOW=1
STRATEGY_CONTROL_ENTRY_MICROPULLBACKEMA=1
STRATEGY_CONTROL_ENTRY_MICROTRENDRETEST=1

# 2026-03-11: blanket entry stop は撤回。loser suppression は worker-local guard /
# setup-scoped participation trim で扱い、shared strategy_control では止めない。
STRATEGY_CONTROL_ENTRY_PRECISIONLOWVOL=1
STRATEGY_CONTROL_ENTRY_WICKREVERSALBLEND=1
STRATEGY_CONTROL_ENTRY_VWAPREVERTS=1
STRATEGY_CONTROL_ENTRY_MICROCOMPRESSIONREVERT=1
STRATEGY_CONTROL_ENTRY_MICROVWAPREVERT=1

LOCAL_FEEDBACK_CYCLE_PARTICIPATION_ALLOCATOR_CMD="/Users/tossaki/App/QuantRabbit/.venv/bin/python /Users/tossaki/App/QuantRabbit/scripts/participation_allocator.py --lookback-hours 6 --min-attempts 10 --setup-min-attempts 2 --max-units-cut 0.35 --max-units-boost 0.30 --max-probability-boost 0.15"

# 2026-03-05 local-v2 recovery/tuning:
# - keep B live but suppress long-side loss concentration
# - tighten C/D/Flow low-quality entries with dynamic thresholds
# - shrink D/Flow oversized units to reduce margin-cap churn
SCALP_PING_5S_B_SIDE_FILTER=sell
SCALP_PING_5S_B_ALLOW_NO_SIDE_FILTER=0
SCALP_PING_5S_B_DIRECTION_BIAS_LONG_OPPOSITE_UNITS_MULT=0.15
