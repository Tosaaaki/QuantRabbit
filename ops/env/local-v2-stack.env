# Local override profile for `scripts/local_v2_stack.sh`.
#
# Keep this file intentionally minimal. Base runtime values come from:
#   ops/env/quant-v2-runtime.env
#
# Add temporary local-only overrides here when running fast PDCA loops.
# Example:
#   SCALP_PING_5S_B_SIDE_FILTER=sell
#   SCALP_PING_5S_B_SHORT_PROBE_RESCUE_ENABLED=0

# 2026-03-05 loss suppression: force B variant to short-only at runtime.
SCALP_PING_5S_B_SIDE_FILTER=short
SCALP_PING_5S_B_ALLOW_NO_SIDE_FILTER=0

# 2026-03-05 dynamic reentry profile (local V2):
# Enable reentry decisions and apply ATR-adaptive thresholds across workers.
REENTRY_ENABLE_ALL=1
REENTRY_SHADOW_ALL=0
REENTRY_ATR_LOW_PIPS=2.0
REENTRY_ATR_HIGH_PIPS=10.0
REENTRY_REVERT_MIN_ATR_LOW=0.60
REENTRY_REVERT_MIN_ATR_HIGH=0.72
REENTRY_TREND_MIN_ATR_LOW=0.64
REENTRY_TREND_MIN_ATR_HIGH=0.52
REENTRY_TREND_MAX_ATR_LOW=0.50
REENTRY_TREND_MAX_ATR_HIGH=0.36
REENTRY_EDGE_MIN_ATR_LOW=0.62
REENTRY_EDGE_MIN_ATR_HIGH=0.46
REENTRY_RANGE_REVERT_BONUS_LOW_ATR=0.18
REENTRY_RANGE_REVERT_BONUS_HIGH_ATR=0.08
REENTRY_RANGE_TREND_PENALTY_LOW_ATR=0.18
REENTRY_RANGE_TREND_PENALTY_HIGH_ATR=0.06
