.DS_Store
.env
.env.*
*.pyc
__pycache__/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
logs/
data/
secrets/
.claude/
.quant_rabbit_live.lock/
.quant_rabbit_live.lock.acquire.guard

# Ephemeral coordination locks for append-only DOJO forward runs. Evidence
# receipts and ledgers remain tracked; these zero-byte local mutexes do not.
research/forward/**/.ai-forward.lock
research/forward/**/.source-collector.lock
research/forward/**/.worker-execution.lock

# Accidentally-created top-level verdict marker files from operator-side
# shell redirection around read-only position sidecars. The real reports live
# under data/*.json and docs/*_report.md; these empty markers must not block a
# live runtime precheck.
/EXTEND
/HOLD
/REVIEW_CLOSE
/RECOMMEND_CLOSE
/STILL_VALID
/WEAKENED
/BROKEN
