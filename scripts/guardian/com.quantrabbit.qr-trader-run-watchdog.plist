<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.quantrabbit.qr-trader-run-watchdog</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>-lc</string>
    <string>cd /Users/tossaki/App/QuantRabbit-live &amp;&amp; PYTHONPATH=src /opt/homebrew/bin/python3 tools/qr_trader_run_watchdog.py</string>
  </array>
  <key>StartInterval</key>
  <integer>300</integer>
  <key>StandardOutPath</key>
  <string>/Users/tossaki/App/QuantRabbit-live/logs/qr_trader_run_watchdog.launchd.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/tossaki/App/QuantRabbit-live/logs/qr_trader_run_watchdog.launchd.err</string>
  <key>WorkingDirectory</key>
  <string>/Users/tossaki/App/QuantRabbit-live</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PYTHONPATH</key>
    <string>src</string>
    <key>QR_TRADER_WATCHDOG_CAN_WAKE</key>
    <string>0</string>
    <key>CODEX_DISABLE_UPDATE_CHECK</key>
    <string>1</string>
  </dict>
</dict>
</plist>
