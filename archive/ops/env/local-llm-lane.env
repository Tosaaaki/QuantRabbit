# Local PC lane (real trading) with local LLM gate.
# Load this only on local runner, not on VM services.

CODEX_LOCAL_LLM_ENABLED=1
CODEX_LOCAL_LLM_MODEL=gpt-oss:20b
CODEX_LOCAL_LLM_CHAT_URL=http://127.0.0.1:11434/api/chat
CODEX_LOCAL_LLM_TIMEOUT_SEC=14
CODEX_LOCAL_LLM_MIN_INTERVAL_SEC=45
CODEX_LOCAL_LLM_MIN_CONF=0.60

# Entry/risk baseline (local lane)
CODEX_SPREAD_CAP_PIPS=0.95
CODEX_MAX_BOT_TRADES=1
CODEX_MAX_UNITS=220
CODEX_MIN_UNITS=100
CODEX_MARGIN_CLOSEOUT_STOP=0.94
CODEX_MARGIN_SOFT_STOP=0.78
CODEX_MARGIN_SEVERE_STOP=0.86

# Dynamic TP/SL envelope (pips)
CODEX_TP_ATR_MULT=1.6
CODEX_SL_ATR_MULT=1.25
CODEX_TP_MAX_PIPS=7.2
CODEX_SL_MAX_PIPS=4.8
