# Bridge env from local lane repo -> main repo comparator.
# Copy to: ops/env/local-lane-bridge.env

# Absolute path to separated local lane repo.
LOCAL_LANE_REPO=/Users/tossaki/Documents/App/QuantRabbitLocalLane

# Local lane JSONL log path written by local bot.
LOCAL_LOG=/Users/tossaki/Documents/App/QuantRabbitLocalLane/state/codex_long_autotrade.log

# VM lane trades db path for comparison.
VM_TRADES_DB=/Users/tossaki/Documents/App/QuantRabbit/logs/trades.db

# Compare parameters.
HOURS=24
MIN_TRADES=5
VM_PREFIX=qr-
LOCAL_PREFIX=codexlhf_
